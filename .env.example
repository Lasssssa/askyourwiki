# GitLab instance URL (without trailing slash)
GITLAB_URL=https://gitlab.mycompany.com

# GitLab Personal Access Token with the "read_api" scope
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# IDs of individual projects to synchronize (comma-separated, optional).
# Usually you don't need this: configure GITLAB_GROUP_IDS instead and every
# project in the group is discovered automatically (see below).
GITLAB_PROJECT_IDS=

# IDs of the groups to synchronize (comma-separated). By default every project
# in these groups (and their subgroups) is discovered and its wiki + root
# READMEs are indexed, so new projects are picked up automatically. The group's
# own wiki (GitLab Premium) is indexed too when present.
GITLAB_GROUP_IDS=78

# Expand groups into their projects (default true). Set to "false" to index only
# the groups' own wikis and the explicitly listed GITLAB_PROJECT_IDS.
SYNC_GROUP_PROJECTS=true
# Descend into subgroups when discovering a group's projects (default true).
SYNC_INCLUDE_SUBGROUPS=true

# LLM backend used for chat: "vllm" (default, self-hosted model) or "anthropic" (hosted API)
LLM_PROVIDER=vllm

# --- Configuration for an OpenAI-compatible self-hosted model (vLLM, etc.) ---
# Base URL of the OpenAI-compatible API (includes the /v1 suffix)
VLLM_BASE_URL=http://localhost:8000/v1
# Model name as exposed by the server (e.g. --served-model-name on vLLM)
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# API key expected by the server (leave as "EMPTY" if no authentication is required)
VLLM_API_KEY=EMPTY

# --- Configuration for the hosted Anthropic API (if LLM_PROVIDER=anthropic) ---
# Provider API key
ANTHROPIC_API_KEY=
# Model identifier to use, see the provider's documentation
ANTHROPIC_MODEL=

# Frequency of automatic synchronization (in minutes)
SYNC_INTERVAL_MINUTES=60

# Port the application listens on
APP_PORT=8000

# Title displayed in the web UI header (optional)
APP_TITLE=GitLab Wiki Assistant

# Retrieval (RAG): rank wiki chunks against each question and send only the most
# relevant ones to the model (needed once the wikis exceed the context budget).
# Set to "false" to fall back to sending all pages up to MAX_CONTEXT_TOKENS.
RETRIEVAL_ENABLED=true
# Token budget for the context sent to the model (also the retrieval budget).
MAX_CONTEXT_TOKENS=150000

# Persist users' chat conversations to disk so they can browse their history
# (stored under data/conversations/). Set to "false" to disable saving.
SAVE_CONVERSATIONS=true

# When GitLab sign-in is enabled, restrict each user to the wikis of the
# projects/groups they can access on GitLab (membership + visibility). Set to
# "false" to let every signed-in user query all indexed wikis. No effect when
# authentication is disabled (the app is then fully open).
ACCESS_CONTROL=true
# Seconds to cache a user's accessible-scope set before re-checking GitLab.
ACCESS_CACHE_TTL=300

# --- "Sign in with GitLab" (OAuth2) ---
# When configured, every route (UI + API) requires signing in with GitLab.
# Register an OAuth application on your GitLab instance (scope: read_user,
# redirect URI: https://<your-app>/auth/gitlab/callback) and fill in:
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
# Redirect URI registered with the application. Leave empty to derive it from
# the incoming request (set it explicitly when running behind a reverse proxy).
GITLAB_OAUTH_REDIRECT_URI=

# Secret used to sign session cookies. Leave empty to derive it from the
# OAuth client secret (sessions then stay valid across restarts).
SESSION_SECRET=
