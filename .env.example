# URL de l'instance GitLab (sans slash final)
GITLAB_URL=https://gitlab.monentreprise.com

# Personal Access Token GitLab avec le scope "read_api"
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# IDs des projets dont on veut synchroniser les wikis (séparés par virgule)
GITLAB_PROJECT_IDS=123,456

# IDs des groupes dont on veut synchroniser les wikis (optionnel, séparés par virgule)
GITLAB_GROUP_IDS=78

# Backend LLM utilisé pour le chat: "vllm" (par défaut, modèle auto-hébergé) ou "anthropic" (API hébergée)
LLM_PROVIDER=vllm

# --- Configuration pour un modèle auto-hébergé compatible OpenAI (vLLM, etc.) ---
# URL de base de l'API compatible OpenAI (inclut le suffixe /v1)
VLLM_BASE_URL=http://localhost:8000/v1
# Nom du modèle tel qu'exposé par le serveur (ex: --served-model-name côté vLLM)
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# Clé API attendue par le serveur (laisser "EMPTY" si aucune authentification n'est requise)
VLLM_API_KEY=EMPTY

# --- Configuration pour l'API hébergée Anthropic (si LLM_PROVIDER=anthropic) ---
# Clé API du fournisseur
ANTHROPIC_API_KEY=
# Identifiant du modèle à utiliser, voir la documentation du fournisseur
ANTHROPIC_MODEL=

# Fréquence de synchronisation automatique (en minutes)
SYNC_INTERVAL_MINUTES=60

# Port d'écoute de l'application
APP_PORT=8000
