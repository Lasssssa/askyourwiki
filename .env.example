# URL de l'instance GitLab (sans slash final)
GITLAB_URL=https://gitlab.monentreprise.com

# Personal Access Token GitLab avec le scope "read_api"
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# IDs des projets dont on veut synchroniser les wikis (séparés par virgule)
GITLAB_PROJECT_IDS=123,456

# IDs des groupes dont on veut synchroniser les wikis (optionnel, séparés par virgule)
GITLAB_GROUP_IDS=78

# Backend LLM utilisé pour le chat: "anthropic" (par défaut) ou "vllm"
LLM_PROVIDER=anthropic

# Clé API Anthropic (requis si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxx

# --- Configuration pour un modèle auto-hébergé via vLLM (si LLM_PROVIDER=vllm) ---
# URL de base de l'API compatible OpenAI exposée par vLLM (inclut le suffixe /v1)
VLLM_BASE_URL=http://localhost:8000/v1
# Nom du modèle tel que servi par vLLM (ex: --served-model-name côté vLLM)
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# Clé API attendue par le serveur vLLM (laisser "EMPTY" si --api-key n'est pas utilisé)
VLLM_API_KEY=EMPTY

# Fréquence de synchronisation automatique (en minutes)
SYNC_INTERVAL_MINUTES=60

# Port d'écoute de l'application
APP_PORT=8000
