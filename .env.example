# GitLab instance URL (without trailing slash)
GITLAB_URL=https://gitlab.mycompany.com

# GitLab Personal Access Token with the "read_api" scope
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# IDs of the projects whose wikis should be synchronized (comma-separated)
GITLAB_PROJECT_IDS=123,456

# IDs of the groups whose wikis should be synchronized (optional, comma-separated)
GITLAB_GROUP_IDS=78

# LLM backend used for chat: "vllm" (default, self-hosted model) or "anthropic" (hosted API)
LLM_PROVIDER=vllm

# --- Configuration for an OpenAI-compatible self-hosted model (vLLM, etc.) ---
# Base URL of the OpenAI-compatible API (includes the /v1 suffix)
VLLM_BASE_URL=http://localhost:8000/v1
# Model name as exposed by the server (e.g. --served-model-name on vLLM)
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# API key expected by the server (leave as "EMPTY" if no authentication is required)
VLLM_API_KEY=EMPTY

# --- Configuration for the hosted Anthropic API (if LLM_PROVIDER=anthropic) ---
# Provider API key
ANTHROPIC_API_KEY=
# Model identifier to use, see the provider's documentation
ANTHROPIC_MODEL=

# Frequency of automatic synchronization (in minutes)
SYNC_INTERVAL_MINUTES=60

# Port the application listens on
APP_PORT=8000

# Title displayed in the web UI header (optional)
APP_TITLE=GitLab Wiki Assistant

# --- Optional shared username/password login ---
# If both are set, every route (UI + API) requires a sign-in.
# Leave both empty to disable password sign-in.
AUTH_USERNAME=
AUTH_PASSWORD=

# --- Optional "Sign in with GitLab" (OAuth2) ---
# Register an OAuth application on your GitLab instance (scope: read_user,
# redirect URI: https://<your-app>/auth/gitlab/callback) and fill in:
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
# Redirect URI registered with the application. Leave empty to derive it from
# the incoming request (set it explicitly when running behind a reverse proxy).
GITLAB_OAUTH_REDIRECT_URI=

# Secret used to sign session cookies. Leave empty to derive it from the
# credentials above (sessions then stay valid across restarts).
SESSION_SECRET=
